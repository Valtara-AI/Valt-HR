# Example environment variables for Valt HR Suite
NEXT_PUBLIC_APP_NAME="Valt HR Suite"
NEXT_PUBLIC_API_BASE_URL="https://api.example.com"
LEADCONNECTOR_WIDGET_ID=67ff121f119caa7e6578236b
NODE_ENV=production
PORT=3000

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/hrwas?schema=public"

# Resume Parsing Service (Affinda API - can switch to Sovren, Rchilli, etc.)
RESUME_PARSER_API_KEY=your_affinda_api_key_here
RESUME_PARSER_API_URL=https://api.affinda.com/v3/resume_parser

# Email Service (SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@valtara.ai
SENDGRID_FROM_NAME="Valtara HR Suite"

# SMS Service (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Calendar Integration (Google Calendar)
GOOGLE_CALENDAR_CLIENT_ID=your_google_client_id
GOOGLE_CALENDAR_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Storage (AWS S3 for resume uploads)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=hrwas-resumes

# ATS Integrations
WORKDAY_API_KEY=your_workday_api_key
WORKDAY_TENANT=your_tenant_name
GREENHOUSE_API_KEY=your_greenhouse_api_key
BAMBOOHR_API_KEY=your_bamboohr_api_key
BAMBOOHR_SUBDOMAIN=your_subdomain

# AI/ML Services (for speech analysis, NLP, sentiment)
OPENAI_API_KEY=your_openai_api_key
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=eastus

# Job Board APIs
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
INDEED_PUBLISHER_ID=your_indeed_publisher_id

# Security
JWT_SECRET=your_jwt_secret_key_min_32_chars
SESSION_SECRET=your_session_secret_key

# Redis (for background job queues)
REDIS_URL=redis://localhost:6379

# Monitoring
SENTRY_DSN=your_sentry_dsn
