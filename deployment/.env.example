# HR Suite Production Environment Variables
# Copy this to .env on the server and fill in your actual values

# Node Environment
NODE_ENV=production
PORT=3000

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/hr_suite
# Or for MongoDB:
# DATABASE_URL=mongodb://localhost:27017/hr_suite

# Authentication & Security
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRATION=7d
SESSION_SECRET=your_session_secret_change_this
BCRYPT_ROUNDS=10

# API Keys (if using external services)
# Stripe
STRIPE_SECRET_KEY=sk_live_your_stripe_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Email Service (e.g., SendGrid, AWS SES)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
FROM_EMAIL=noreply@valtara.ai

# AWS (if using S3, etc.)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET=hr-suite-uploads

# Redis (if using for caching/sessions)
REDIS_URL=redis://localhost:6379

# Application URLs
APP_URL=https://hr-suite.valtara.ai
API_URL=https://hr-suite.valtara.ai/api

# Feature Flags
ENABLE_ANALYTICS=true
ENABLE_DEBUG_LOGGING=false

# Third-party Integrations
# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=https://hr-suite.valtara.ai

# Logging
LOG_LEVEL=info
LOG_FILE=/home/ubuntu/logs/app.log
